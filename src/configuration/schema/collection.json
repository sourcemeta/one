{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcemeta One Collection",
  "description": "Represents a set of schemas to be mounted into the One",
  "examples": [
    {
      "title": "My Schema Collection",
      "description": "A collection of JSON Schemas",
      "path": "schemas"
    }
  ],
  "x-lint-exclude": [ "simple_properties_identifiers" ],
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "x-sourcemeta-one:alert": {
      "type": "string"
    },
    "x-sourcemeta-one:evaluate": {
      "type": "boolean"
    },
    "x-sourcemeta-one:path": {
      "type": "string"
    },
    "x-sourcemeta-one:priority": {
      "type": "integer",
      "maximum": 100,
      "minimum": 0
    },
    "baseUri": {
      "x-format-assertion": true,
      "type": "string",
      "format": "uri-reference"
    },
    "defaultDialect": {
      "x-format-assertion": true,
      "type": "string",
      "format": "uri-reference"
    },
    "email": {
      "x-format-assertion": true,
      "type": "string",
      "format": "email"
    },
    "github": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "resolve": {
      "type": "object",
      "propertyNames": {
        "x-format-assertion": true,
        "format": "uri-reference"
      },
      "additionalProperties": {
        "x-format-assertion": true,
        "type": "string",
        "format": "uri-reference"
      }
    },
    "website": {
      "x-format-assertion": true,
      "type": "string",
      "format": "uri"
    },
    "lint": {
      "type": "object",
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "ignore": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
