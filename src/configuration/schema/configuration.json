{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "The Sourcemeta One configuration file format",
  "description": "The configuration file format used to configured One instances",
  "examples": [
    {
      "url": "https://schemas.example.com"
    }
  ],
  "type": "object",
  "required": [ "url" ],
  "properties": {
    "extends": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "contents": {
      "$ref": "./contents.json"
    },
    "api": {
      "type": [ "object", "boolean" ],
      "additionalProperties": false
    },
    "html": {
      "type": [ "object", "boolean" ],
      "properties": {
        "description": {
          "type": "string"
        },
        "action": {
          "type": "object",
          "required": [ "title", "url", "icon" ],
          "properties": {
            "title": {
              "type": "string"
            },
            "icon": {
              "type": "string"
            },
            "url": {
              "x-format-assertion": true,
              "type": "string",
              "format": "uri"
            }
          },
          "additionalProperties": false
        },
        "head": {
          "type": "string"
        },
        "hero": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "url": {
      "x-format-assertion": true,
      "type": "string",
      "format": "uri"
    },
    "authentication": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "anyOf": [
          {
            "type": "object",
            "required": [ "type", "algorithm", "name", "paths", "keys" ],
            "properties": {
              "type": {
                "const": "apiKey"
              },
              "algorithm": {
                "enum": [ "identity", "sha256" ]
              },
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9-]+$"
              },
              "paths": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "pattern": "^/",
                  "minLength": 1
                }
              },
              "keys": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "object",
                  "required": [ "environmentVariable" ],
                  "properties": {
                    "environmentVariable": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": [
              "type",
              "name",
              "paths",
              "issuer",
              "audience",
              "algorithms"
            ],
            "properties": {
              "type": {
                "const": "jwt"
              },
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9-]+$"
              },
              "paths": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "pattern": "^/",
                  "minLength": 1
                }
              },
              "issuer": {
                "type": "string",
                "minLength": 1
              },
              "audience": {
                "type": "string",
                "minLength": 1
              },
              "jwksUri": {
                "type": "string",
                "minLength": 1
              },
              "algorithms": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "enum": [
                    "RS256",
                    "RS384",
                    "RS512",
                    "PS256",
                    "PS384",
                    "PS512",
                    "ES256",
                    "ES384",
                    "ES512",
                    "EdDSA"
                  ]
                }
              }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false,
  "dependentSchemas": {
    "api": {
      "if": {
        "properties": {
          "api": {
            "const": false
          }
        }
      },
      "then": {
        "required": [ "html" ],
        "properties": {
          "html": {
            "const": false
          }
        }
      }
    }
  }
}
