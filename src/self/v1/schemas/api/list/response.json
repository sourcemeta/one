{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcemeta One List API Response",
  "description": "The response format for the directory listing API endpoint",
  "examples": [
    {
      "health": 100,
      "schemas": 42,
      "entries": [],
      "path": "/schemas",
      "url": "https://example.com/schemas",
      "policies": [],
      "breadcrumb": [
        {
          "name": "Home",
          "path": "/"
        }
      ]
    }
  ],
  "type": "object",
  "required": [
    "health",
    "schemas",
    "entries",
    "path",
    "url",
    "breadcrumb",
    "policies"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "policies": {
      "$ref": "#/$defs/policies"
    },
    "description": {
      "type": "string"
    },
    "breadcrumb": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [ "name", "path" ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "x-format-assertion": true,
            "type": "string",
            "format": "uri-reference"
          }
        },
        "additionalProperties": false
      }
    },
    "email": {
      "x-format-assertion": true,
      "type": "string",
      "format": "email"
    },
    "entries": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "required": [
              "health",
              "schemas",
              "name",
              "type",
              "path",
              "policies"
            ],
            "properties": {
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "policies": {
                "$ref": "#/$defs/policies"
              },
              "type": {
                "const": "directory"
              },
              "email": {
                "x-format-assertion": true,
                "type": "string",
                "format": "email"
              },
              "github": {
                "type": "string"
              },
              "health": {
                "type": "integer",
                "maximum": 100,
                "minimum": 0
              },
              "schemas": {
                "type": "integer",
                "minimum": 0
              },
              "name": {
                "type": "string"
              },
              "path": {
                "x-format-assertion": true,
                "type": "string",
                "format": "uri-reference"
              },
              "website": {
                "x-format-assertion": true,
                "type": "string",
                "format": "uri"
              }
            },
            "additionalProperties": false
          },
          {
            "$ref": "../schemas/metadata/response.json#base",
            "required": [ "type", "name", "policies" ],
            "properties": {
              "type": {
                "const": "schema"
              },
              "name": {
                "type": "string"
              },
              "policies": {
                "$ref": "#/$defs/policies"
              }
            },
            "unevaluatedProperties": false
          }
        ]
      }
    },
    "github": {
      "type": "string"
    },
    "health": {
      "type": "integer",
      "maximum": 100,
      "minimum": 0
    },
    "schemas": {
      "type": "integer",
      "minimum": 0
    },
    "path": {
      "x-format-assertion": true,
      "type": "string",
      "format": "uri-reference"
    },
    "url": {
      "x-format-assertion": true,
      "type": "string",
      "format": "uri"
    },
    "website": {
      "x-format-assertion": true,
      "type": "string",
      "format": "uri"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "policies": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    }
  }
}
