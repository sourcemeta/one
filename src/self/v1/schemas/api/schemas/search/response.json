{
  "$schema": "https://schemas.sourcemeta.com/self/v1/schemas/meta",
  "title": "Sourcemeta One Schema Search API Response",
  "description": "The response format for the schema search API endpoint",
  "examples": [
    [
      {
        "path": "/schemas/user.json",
        "identifier": "https://example.com/schemas/user.json",
        "title": "User Schema",
        "description": "Defines a user object",
        "priority": 50,
        "health": 100
      }
    ]
  ],
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "path",
      "identifier",
      "title",
      "description",
      "priority",
      "health"
    ],
    "properties": {
      "title": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "path": {
        "type": "string",
        "format": "uri-reference"
      },
      "identifier": {
        "type": "string",
        "format": "uri"
      },
      "priority": {
        "type": "integer",
        "maximum": 100,
        "minimum": 0
      },
      "health": {
        "type": "integer",
        "maximum": 100,
        "minimum": 0
      }
    },
    "additionalProperties": false
  }
}
