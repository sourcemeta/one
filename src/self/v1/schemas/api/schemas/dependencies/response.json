{
  "$schema": "https://schemas.sourcemeta.com/self/v1/schemas/meta",
  "title": "Sourcemeta One Schema Dependencies API Response",
  "description": "The response format for the schema dependencies API endpoint",
  "examples": [
    [
      {
        "from": "https://example.com/schemas/user.json",
        "to": "https://example.com/schemas/address.json",
        "at": "/properties/address"
      }
    ]
  ],
  "type": "array",
  "items": {
    "type": "object",
    "required": [ "from", "to", "at" ],
    "properties": {
      "at": {
        "type": "string",
        "format": "json-pointer"
      },
      "from": {
        "type": "string",
        "format": "uri"
      },
      "to": {
        "type": "string",
        "format": "uri"
      }
    },
    "additionalProperties": false
  }
}
