{
  "$schema": "https://schemas.sourcemeta.com/self/v1/schemas/meta",
  "title": "Sourcemeta One MCP Request",
  "description": "Any incoming MCP request the server accepts. The body may be a single JSON-RPC envelope or a JSON-RPC 2.0 batch (an array of envelopes) on protocol version `2025-03-26`",
  "examples": [
    {
      "jsonrpc": "2.0",
      "id": 1,
      "method": "initialize",
      "params": {
        "protocolVersion": "2025-11-25",
        "capabilities": {},
        "clientInfo": {
          "name": "claude-code",
          "version": "1.0.0"
        }
      }
    },
    {
      "jsonrpc": "2.0",
      "method": "notifications/initialized"
    },
    {
      "jsonrpc": "2.0",
      "id": 2,
      "method": "ping"
    },
    {
      "jsonrpc": "2.0",
      "id": 10,
      "method": "resources/list"
    },
    {
      "jsonrpc": "2.0",
      "id": 12,
      "method": "resources/templates/list"
    },
    {
      "jsonrpc": "2.0",
      "id": 20,
      "method": "resources/read",
      "params": {
        "uri": "https://example.com/v1/foo/v1/example"
      }
    },
    {
      "jsonrpc": "2.0",
      "id": 50,
      "method": "tools/list"
    },
    {
      "jsonrpc": "2.0",
      "id": 51,
      "method": "tools/call",
      "params": {
        "name": "list_directory",
        "arguments": {}
      }
    },
    [
      {
        "jsonrpc": "2.0",
        "id": 100,
        "method": "ping"
      },
      {
        "jsonrpc": "2.0",
        "id": 101,
        "method": "resources/list"
      }
    ]
  ],
  "oneOf": [
    {
      "$ref": "#/$defs/single"
    },
    {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/single"
      }
    }
  ],
  "$defs": {
    "single": {
      "$comment": "Any single JSON-RPC envelope the server accepts (request or notification)",
      "anyOf": [
        {
          "$ref": "./initialize/request.json"
        },
        {
          "$ref": "./notifications/initialized.json"
        },
        {
          "$ref": "./notifications/cancelled.json"
        },
        {
          "$ref": "./ping/request.json"
        },
        {
          "$ref": "./resources/list/request.json"
        },
        {
          "$ref": "./resources/templates/list/request.json"
        },
        {
          "$ref": "./resources/read/request.json"
        },
        {
          "$ref": "./tools/list/request.json"
        },
        {
          "$ref": "./tools/call/request.json"
        }
      ]
    }
  }
}
