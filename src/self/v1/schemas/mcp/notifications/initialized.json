  "examples": [
    {
      "jsonrpc": "2.0",
      "method": "notifications/initialized"
    }
  ],
  "type": "object",
  "required": [ "jsonrpc", "method" ],
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "method": {
      "const": "notifications/initialized"
    },
    "params": {
      "type": "object",
      "properties": {
        "_meta": {
          "type": "object"
        }
      }
    }
  }
}
