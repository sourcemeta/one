{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcemeta One MCP Resources List Response",
  "description": "Sourcemeta One's list of MCP resources",
  "examples": [
    {
      "jsonrpc": "2.0",
      "id": 10,
      "result": {
        "resources": [
          {
            "uri": "https://example.com/v1/example/string",
            "name": "string",
            "description": "An example string schema",
            "mimeType": "application/schema+json",
            "size": 143
          },
          {
            "uri": "https://example.com/v1/example/string?bundle=1",
            "name": "string",
            "description": "An example string schema",
            "mimeType": "application/schema+json",
            "size": 143
          },
          {
            "uri": "https://example.com/v1/no-description",
            "name": "no-description",
            "mimeType": "application/schema+json",
            "size": 64
          }
        ],
        "nextCursor": "100"
      }
    },
    {
      "jsonrpc": "2.0",
      "id": 11,
      "result": {
        "resources": []
      }
    }
  ],
  "type": "object",
  "required": [ "jsonrpc", "id", "result" ],
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "type": [ "string", "integer" ]
    },
    "result": {
      "type": "object",
      "required": [ "resources" ],
      "properties": {
        "resources": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "required": [ "uri", "name", "mimeType", "size" ],
            "properties": {
              "uri": {
                "$comment": "TODO: Use Format Assertion when supported on Blaze",
                "type": "string",
                "format": "uri"
              },
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "mimeType": {
                "const": "application/schema+json"
              },
              "size": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        },
        "nextCursor": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
