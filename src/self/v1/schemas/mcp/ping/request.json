{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcemeta One MCP Ping Request",
  "description": "Liveness check from a client",
  "examples": [
    {
      "jsonrpc": "2.0",
      "id": 5,
      "method": "ping"
    },
    {
      "jsonrpc": "2.0",
      "id": 5,
      "method": "ping",
      "params": {}
    }
  ],
  "type": "object",
  "required": [ "jsonrpc", "id", "method" ],
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "type": [ "string", "integer" ]
    },
    "method": {
      "const": "ping"
    },
    "params": {
      "type": "object"
    }
  }
}
