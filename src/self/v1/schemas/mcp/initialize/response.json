{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcemeta One MCP Initialize Response",
  "description": "Sourcemeta One's response to a client's initialization",
  "examples": [
    {
      "jsonrpc": "2.0",
      "id": 1,
      "result": {
        "protocolVersion": "2025-11-25",
        "capabilities": {
          "resources": {}
        },
        "serverInfo": {
          "name": "sourcemeta-one-enterprise",
          "title": "Sourcemeta One Enterprise",
          "version": "1.0.0",
          "description": "A JSON Schema registry",
          "websiteUrl": "https://example.com"
        },
        "instructions": "Server instructions"
      }
    }
  ],
  "type": "object",
  "required": [ "jsonrpc", "id", "result" ],
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "type": [ "string", "integer" ]
    },
    "result": {
      "type": "object",
      "required": [
        "protocolVersion",
        "capabilities",
        "serverInfo",
        "instructions"
      ],
      "properties": {
        "protocolVersion": {
          "enum": [ "2025-11-25", "2025-06-18", "2025-03-26" ]
        },
        "capabilities": {
          "type": "object",
          "required": [ "resources" ],
          "properties": {
            "resources": {
              "type": "object",
              "additionalProperties": false
            },
            "tools": {
              "type": "object",
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "serverInfo": {
          "type": "object",
          "required": [ "name", "version" ],
          "properties": {
            "name": {
              "enum": [ "sourcemeta-one", "sourcemeta-one-enterprise" ]
            },
            "title": {
              "type": "string"
            },
            "version": {
              "type": "string"
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "websiteUrl": {
              "type": "string",
              "format": "uri"
            }
          },
          "additionalProperties": false
        },
        "instructions": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
