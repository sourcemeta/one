{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcemeta One MCP Response",
  "description": "Any outgoing MCP response the server returns",
  "examples": [
    {
      "jsonrpc": "2.0",
      "id": 1,
      "result": {
        "protocolVersion": "2025-11-25",
        "capabilities": {
          "resources": {}
        },
        "serverInfo": {
          "name": "sourcemeta-one-enterprise",
          "title": "Sourcemeta One Enterprise",
          "version": "1.0.0"
        }
      }
    },
    {
      "jsonrpc": "2.0",
      "id": 2,
      "result": {}
    },
    {
      "jsonrpc": "2.0",
      "error": {
        "code": -32700,
        "message": "Parse error"
      }
    },
    {
      "jsonrpc": "2.0",
      "id": 10,
      "result": {
        "resources": []
      }
    },
    {
      "jsonrpc": "2.0",
      "id": 12,
      "result": {
        "resourceTemplates": [
          {
            "uriTemplate": "https://example.com/v1/{+path}{?bundle}",
            "name": "JSON Schema",
            "description": "A JSON Schema in this catalog (optionally bundled)",
            "mimeType": "application/schema+json"
          }
        ]
      }
    },
    {
      "jsonrpc": "2.0",
      "id": 20,
      "result": {
        "contents": [
          {
            "uri": "https://example.com/v1/foo/v1/example",
            "mimeType": "application/schema+json",
            "text": "{\n  \"$id\": \"https://example.com/v1/foo/v1/example\",\n  \"type\": \"object\"\n}"
          }
        ]
      }
    }
  ],
  "anyOf": [
    {
      "$ref": "./initialize/response.json"
    },
    {
      "$ref": "./ping/response.json"
    },
    {
      "$ref": "./error.json"
    },
    {
      "$ref": "./resources/list/response.json"
    },
    {
      "$ref": "./resources/templates/list/response.json"
    },
    {
      "$ref": "./resources/read/response.json"
    }
  ]
}
