{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcemeta One MCP Tools Call Response",
  "description": "Sourcemeta One's response to a tool invocation",
  "examples": [
    {
      "jsonrpc": "2.0",
      "id": 51,
      "result": {
        "content": [
          {
            "type": "text",
            "text": "{\n  \"valid\": true\n}"
          }
        ],
        "structuredContent": {
          "valid": true
        },
        "isError": false
      }
    },
    {
      "jsonrpc": "2.0",
      "id": 52,
      "result": {
        "content": [
          {
            "type": "text",
            "text": "Schema not found"
          }
        ],
        "isError": true
      }
    },
    {
      "jsonrpc": "2.0",
      "id": 53,
      "result": {
        "content": [
          {
            "type": "text",
            "text": "{\"results\":[{\"path\":\"/test/object\",\"identifier\":\"https://example.com/test/object\",\"title\":\"My Object\",\"description\":\"An Object Example\"}]}"
          },
          {
            "type": "resource_link",
            "uri": "https://example.com/test/object",
            "name": "My Object",
            "description": "An Object Example",
            "mimeType": "application/schema+json"
          }
        ],
        "structuredContent": {
          "results": [
            {
              "path": "/test/object",
              "identifier": "https://example.com/test/object",
              "title": "My Object",
              "description": "An Object Example"
            }
          ]
        },
        "isError": false
      }
    }
  ],
  "type": "object",
  "required": [ "jsonrpc", "id", "result" ],
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "type": [ "string", "integer" ]
    },
    "result": {
      "anyOf": [
        {
          "type": "object",
          "required": [ "content", "isError" ],
          "properties": {
            "content": {
              "$ref": "#/$defs/content"
            },
            "structuredContent": {
              "$comment": "Per the Model Context Protocol specification, structuredContent is 'An optional JSON object that represents the structured result of the tool call' (https://modelcontextprotocol.io/specification/2025-06-18/server/tools#structured-content)",
              "type": "object"
            },
            "isError": {
              "const": false
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "content", "isError" ],
          "properties": {
            "content": {
              "$ref": "#/$defs/content"
            },
            "isError": {
              "const": true
            }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "content": {
      "type": "array",
      "minItems": 1,
      "prefixItems": [
        {
          "type": "object",
          "required": [ "type", "text" ],
          "properties": {
            "type": {
              "const": "text"
            },
            "text": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ],
      "items": {
        "anyOf": [
          {
            "type": "object",
            "required": [ "type", "text" ],
            "properties": {
              "type": {
                "const": "text"
              },
              "text": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": [ "type", "uri", "mimeType" ],
            "properties": {
              "type": {
                "const": "resource_link"
              },
              "uri": {
                "$comment": "TODO: Use Format Assertion when supported on Blaze",
                "type": "string",
                "format": "uri"
              },
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "mimeType": {
                "const": "application/schema+json"
              }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  }
}
