{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcemeta One Schema Dependencies RPC Output",
  "description": "Get all direct and indirect dependencies of a schema in the catalog",
  "examples": [
    {
      "results": [
        {
          "from": "https://example.com/schemas/user.json",
          "to": "https://example.com/schemas/address.json",
          "at": "/properties/address/$ref"
        }
      ]
    }
  ],
  "type": "object",
  "required": [ "results" ],
  "properties": {
    "results": {
      "$ref": "../../../../api/schemas/dependencies/response.json"
    }
  },
  "additionalProperties": false
}
