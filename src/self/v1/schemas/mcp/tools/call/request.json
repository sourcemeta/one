{
  "$schema": "https://schemas.sourcemeta.com/self/v1/schemas/meta",
  "title": "Sourcemeta One MCP Tools Call Request",
  "description": "Request from a client to invoke an MCP tool by name",
  "examples": [
    {
      "jsonrpc": "2.0",
      "id": 51,
      "method": "tools/call",
      "params": {
        "name": "list_directory",
        "arguments": {}
      }
    }
  ],
  "type": "object",
  "required": [ "jsonrpc", "id", "method", "params" ],
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "type": [ "string", "integer" ]
    },
    "method": {
      "const": "tools/call"
    },
    "params": {
      "type": "object",
      "required": [ "name" ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]{0,63}$"
        },
        "arguments": {
          "type": "object"
        },
        "_meta": {
          "type": "object",
          "properties": {
            "progressToken": {
              "type": [ "string", "integer" ]
            }
          }
        }
      }
    }
  }
}
