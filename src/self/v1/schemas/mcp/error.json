{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcemeta One MCP Error Response",
  "description": "The error response Sourcemeta One returns when an MCP request fails",
  "examples": [
    {
      "jsonrpc": "2.0",
      "id": null,
      "error": {
        "code": -32700,
        "message": "Parse error"
      }
    },
    {
      "jsonrpc": "2.0",
      "id": 21,
      "error": {
        "code": -32007,
        "message": "Foreign URI",
        "data": "This URI lies outside this catalog's namespace. Query the appropriate registry instead"
      }
    }
  ],
  "type": "object",
  "required": [ "jsonrpc", "id", "error" ],
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "type": [ "string", "integer", "null" ]
    },
    "error": {
      "anyOf": [
        {
          "$ref": "#/$defs/standard"
        },
        {
          "$ref": "#/$defs/custom"
        }
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "standard": {
      "$comment": "JSON-RPC reserved error codes",
      "anyOf": [
        {
          "const": {
            "code": -32700,
            "message": "Parse error"
          }
        },
        {
          "const": {
            "code": -32600,
            "message": "Invalid Request"
          }
        },
        {
          "const": {
            "code": -32601,
            "message": "Method not found"
          }
        },
        {
          "const": {
            "code": -32603,
            "message": "Internal error"
          }
        },
        {
          "type": "object",
          "required": [ "code", "message", "data" ],
          "properties": {
            "code": {
              "const": -32602
            },
            "message": {
              "const": "Params fail against the tool request schema"
            },
            "data": {
              "$ref": "../api/schemas/evaluate/response.json"
            }
          },
          "additionalProperties": false
        },
        {
          "const": {
            "code": -32602,
            "message": "Invalid resource schema URI",
            "data": "URIs accepted by resources/read must not contain a fragment and may only carry an optional `bundle` query parameter"
          }
        },
        {
          "const": {
            "code": -32602,
            "message": "Invalid tool name",
            "data": "Use `tools/list` to discover the available tools"
          }
        },
        {
          "const": {
            "code": -32602,
            "message": "Invalid resource list cursor",
            "data": "Use the `nextCursor` returned by a prior resources/list response, or omit it to start from the beginning"
          }
        },
        {
          "const": {
            "code": -32602,
            "message": "Invalid tool input schema URI",
            "data": "The schema must be an absolute URI without a fragment or query parameters"
          }
        },
        {
          "const": {
            "code": -32002,
            "message": "Resource not found"
          }
        }
      ]
    },
    "custom": {
      "$comment": "Implementation-defined server-error codes within the JSON-RPC reserved range -32099..-32000",
      "anyOf": [
        {
          "const": {
            "code": -32000,
            "message": "Enterprise edition required",
            "data": "MCP support is only available in the Enterprise edition of Sourcemeta One"
          }
        },
        {
          "type": "object",
          "required": [ "code", "message", "data" ],
          "properties": {
            "code": {
              "const": -32001
            },
            "message": {
              "const": "Forbidden origin"
            },
            "data": {
              "description": "The rejected `Origin` header value, echoed back verbatim. May be a URI or the literal string `null` per RFC 6454 §6 for opaque origins",
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "code", "message", "data" ],
          "properties": {
            "code": {
              "const": -32003
            },
            "message": {
              "const": "Unsupported protocol version"
            },
            "data": {
              "type": "object",
              "required": [ "current", "supported" ],
              "properties": {
                "current": {
                  "description": "The `MCP-Protocol-Version` header value the client sent, echoed back verbatim",
                  "type": "string"
                },
                "supported": {
                  "description": "The protocol versions this server implements, in chronological order",
                  "const": [ "2025-03-26", "2025-06-18", "2025-11-25" ]
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        {
          "const": {
            "code": -32004,
            "message": "Method not allowed"
          }
        },
        {
          "const": {
            "code": -32005,
            "message": "Request too large"
          }
        },
        {
          "const": {
            "code": -32006,
            "message": "Unsupported operation",
            "data": "Batch operations are not supported in this protocol version yet"
          }
        },
        {
          "const": {
            "code": -32007,
            "message": "Foreign URI",
            "data": "This URI lies outside this catalog's namespace. Query the appropriate registry instead"
          }
        }
      ]
    }
  }
}
