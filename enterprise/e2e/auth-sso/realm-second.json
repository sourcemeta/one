{
  "realm": "second",
  "enabled": true,
  "sslRequired": "none",
  "clients": [
    {
      "clientId": "registry",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "registry-client-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8000/self/v1/auth/callback/other"
      ],
      "fullScopeAllowed": false,
      "defaultClientScopes": [ "basic" ],
      "optionalClientScopes": [],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "users": [
    {
      "username": "jane",
      "enabled": true,
      "emailVerified": true,
      "email": "jane@acme.test",
      "firstName": "Jane",
      "lastName": "Doe",
      "credentials": [
        {
          "type": "password",
          "value": "jane-password",
          "temporary": false
        }
      ]
    }
  ]
}
