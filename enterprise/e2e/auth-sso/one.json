{
  "url": "http://localhost:8000",
  "html": {
    "name": "SSO Sandbox",
    "description": "A registry whose private catalogs are gated by a single interactive OpenID Connect policy"
  },
  "authentication": [
    {
      "type": "oidc",
      "name": "keycloak",
      "title": "Corporate SSO",
      "paths": [ "/private", "/archive", "/shared" ],
      "issuer": "http://keycloak:8080/realms/main",
      "clientId": "registry",
      "clientSecret": { "environmentVariable": "ONE_E2E_OIDC_CLIENT_SECRET" },
      "sessionSecret": { "environmentVariable": "ONE_E2E_OIDC_SESSION_SECRET" }
    },
    {
      "type": "oidc",
      "name": "other",
      "title": "Partner Login",
      "paths": [ "/shared" ],
      "issuer": "http://keycloak:8080/realms/second",
      "clientId": "registry",
      "clientSecret": { "environmentVariable": "ONE_E2E_OIDC_CLIENT_SECRET" },
      "sessionSecret": { "environmentVariable": "ONE_E2E_OIDC_SESSION_SECRET" }
    }
  ],
  "contents": {
    "public": {
      "path": "./schemas/public"
    },
    "private": {
      "path": "./schemas/private"
    },
    "archive": {
      "path": "./schemas/archive"
    },
    "shared": {
      "path": "./schemas/shared"
    }
  }
}
