{
  "url": "http://localhost:8000",
  "html": {
    "name": "Authentication Sandbox",
    "description": "Fixtures exercising a public registry with apiKey-gated components"
  },
  "authentication": [
    {
      "type": "apiKey",
      "algorithm": "identity",
      "name": "reports",
      "paths": [ "/private", "/reports" ],
      "keys": [
        { "environmentVariable": "ONE_E2E_KEY_PRIMARY" },
        { "environmentVariable": "ONE_E2E_KEY_SECONDARY" }
      ]
    },
    {
      "type": "apiKey",
      "algorithm": "identity",
      "name": "internal",
      "paths": [ "/internal" ],
      "keys": [ { "environmentVariable": "ONE_E2E_KEY_INTERNAL" } ]
    },
    {
      "type": "apiKey",
      "algorithm": "identity",
      "name": "surface",
      "paths": [ "/self/v1/health" ],
      "keys": [ { "environmentVariable": "ONE_E2E_KEY_SURFACE" } ]
    },
    {
      "type": "apiKey",
      "algorithm": "identity",
      "name": "mixed-plain",
      "paths": [ "/mixed" ],
      "keys": [ { "environmentVariable": "ONE_E2E_KEY_MIXED_PLAIN" } ]
    },
    {
      "type": "apiKey",
      "algorithm": "sha256",
      "name": "mixed-hashed",
      "paths": [ "/mixed" ],
      "keys": [ { "environmentVariable": "ONE_E2E_KEY_MIXED_HASHED" } ]
    },
    {
      "type": "jwt",
      "name": "machine",
      "paths": [ "/machine" ],
      "issuer": "http://hydra:4444",
      "audience": "https://schemas.example.com",
      "algorithms": [ "RS256" ]
    },
    {
      "type": "jwt",
      "name": "telemetry",
      "paths": [ "/telemetry" ],
      "issuer": "http://hydra:4444",
      "audience": "https://reports.example.com",
      "jwksUri": "http://hydra:4444/.well-known/jwks.json",
      "algorithms": [ "RS256" ]
    },
    {
      "type": "jwt",
      "name": "strict",
      "paths": [ "/strict" ],
      "issuer": "http://hydra:4444",
      "audience": "https://schemas.example.com",
      "algorithms": [ "ES256" ]
    }
  ],
  "contents": {
    "public": { "path": "./schemas/public" },
    "private": { "path": "./schemas/private" },
    "reports": { "path": "./schemas/reports" },
    "internal": { "path": "./schemas/internal" },
    "orphan": { "path": "./schemas/orphan" },
    "mixed": { "path": "./schemas/mixed" },
    "machine": { "path": "./schemas/machine" },
    "telemetry": { "path": "./schemas/telemetry" },
    "strict": { "path": "./schemas/strict" }
  }
}
