{
  "url": "http://localhost:8000",
  "html": {
    "name": "Authentication Sandbox",
    "description": "Fixtures exercising a public registry with apiKey-gated components"
  },
  "authentication": [
    {
      "type": "apiKey",
      "algorithm": "identity",
      "name": "reports",
      "paths": [ "/private", "/reports" ],
      "keys": [
        { "environmentVariable": "ONE_E2E_KEY_PRIMARY" },
        { "environmentVariable": "ONE_E2E_KEY_SECONDARY" }
      ]
    },
    {
      "type": "apiKey",
      "algorithm": "identity",
      "name": "internal",
      "paths": [ "/internal" ],
      "keys": [ { "environmentVariable": "ONE_E2E_KEY_INTERNAL" } ]
    },
    {
      "type": "apiKey",
      "algorithm": "identity",
      "name": "surface",
      "paths": [ "/self/v1/health" ],
      "keys": [ { "environmentVariable": "ONE_E2E_KEY_SURFACE" } ]
    }
  ],
  "contents": {
    "public": { "path": "./schemas/public" },
    "private": { "path": "./schemas/private" },
    "reports": { "path": "./schemas/reports" },
    "internal": { "path": "./schemas/internal" },
    "orphan": { "path": "./schemas/orphan" }
  }
}
