{
  "url": "http://localhost:8000",
  "html": {
    "name": "Fully Private Sandbox",
    "description": "A registry locked in its entirety, opened by an apiKey, a JWT, or an interactive session"
  },
  "authentication": [
    {
      "type": "apiKey",
      "algorithm": "identity",
      "name": "registry",
      "paths": [ "/" ],
      "keys": [ { "environmentVariable": "ONE_E2E_FULL_KEY" } ]
    },
    {
      "type": "jwt",
      "name": "machine",
      "paths": [ "/" ],
      "issuer": "http://keycloak:8080/realms/main",
      "audience": "https://schemas.example.com",
      "algorithms": [ "RS256" ]
    },
    {
      "type": "oidc",
      "name": "keycloak",
      "paths": [ "/" ],
      "issuer": "http://keycloak:8080/realms/main",
      "clientId": "registry",
      "clientSecret": {
        "environmentVariable": "ONE_E2E_OIDC_CLIENT_SECRET"
      },
      "sessionSecret": {
        "environmentVariable": "ONE_E2E_OIDC_SESSION_SECRET"
      }
    }
  ],
  "contents": {
    "catalog": { "path": "./schemas" }
  }
}
