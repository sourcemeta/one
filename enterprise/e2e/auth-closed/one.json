{
  "url": "http://localhost:8000",
  "html": {
    "name": "Fully Private Sandbox",
    "description": "A registry locked in its entirety, opened by either an apiKey or a JWT"
  },
  "authentication": [
    {
      "type": "apiKey",
      "algorithm": "identity",
      "name": "registry",
      "paths": [ "/" ],
      "keys": [ { "environmentVariable": "ONE_E2E_FULL_KEY" } ]
    },
    {
      "type": "jwt",
      "name": "machine",
      "paths": [ "/" ],
      "issuer": "http://keycloak:8080/realms/main",
      "audience": "https://schemas.example.com",
      "algorithms": [ "RS256" ]
    }
  ],
  "contents": {
    "catalog": { "path": "./schemas" }
  }
}
